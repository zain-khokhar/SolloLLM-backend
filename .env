SOLOLLM_DEBUG=false
SOLOLLM_HOST=0.0.0.0
SOLOLLM_PORT=8000
SOLOLLM_PUBLIC_BASE_URL=https://appear-capable-judy-irc.trycloudflare.com
SOLOLLM_DATA_DIR=/home/zain/SolloLLM-backend/data

# Ollama
SOLOLLM_OLLAMA_BASE_URL=http://127.0.0.1:11434
SOLOLLM_OLLAMA_AUTO_START=false
SOLOLLM_MAX_POWER_MODE=true

# CORS (JSON required)
SOLOLLM_CORS_ORIGINS=["https://sollo-llm-frontend.vercel.app"]
SOLOLLM_CORS_ORIGIN_REGEX="^https://.*\\.vercel\\.app$"

# Allowed hosts (STRING, NOT JSON)
SOLOLLM_ALLOWED_HOSTS=["api.your-domain.com","localhost","127.0.0.1","192.168.18.21","154.192.45.133","*.trycloudflare.com","sollo-llm-frontend.vercel.app"]

# Auth
SOLOLLM_PRIVATE_ACCESS_ENABLED=true
SOLOLLM_OWNER_USERNAME=zain
SOLOLLM_OWNER_PASSWORD=zainkhokhar@1
SOLOLLM_SESSION_SECRET=4dc2e871-ec0d-4fd6-a7a0-496aa9c40511

# Features
SOLOLLM_AGENT_ENABLED=true
SOLOLLM_ACADEMIC_ENABLED=true
SOLOLLM_EXPORT_IMPORT_ENABLED=true
SOLOLLM_TRAINING_ENABLED=true
SOLOLLM_QUANTIZE_ENABLED=true
SOLOLLM_RUNTIME_MANAGEMENT_ENABLED=true

# Admin token
SOLOLLM_ADMIN_API_TOKEN=