SOLOLLM_DEBUG=false
SOLOLLM_HOST=127.0.0.1
SOLOLLM_PORT=8000
SOLOLLM_PUBLIC_BASE_URL=https://api.your-domain.com
SOLOLLM_DATA_DIR=/var/lib/solollm

# Keep Ollama local to the server.
SOLOLLM_OLLAMA_BASE_URL=http://127.0.0.1:11434
SOLOLLM_OLLAMA_AUTO_START=false
SOLOLLM_MAX_POWER_MODE=false

# Frontend access
SOLOLLM_CORS_ORIGINS=https://solollm.vercel.app/
# Optional: enable Vercel preview deployments.
# SOLOLLM_CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$
SOLOLLM_ALLOWED_HOSTS=api.your-domain.com,localhost,127.0.0.1

# Private owner-only access.
SOLOLLM_PRIVATE_ACCESS_ENABLED=true
SOLOLLM_OWNER_USERNAME=zain
SOLOLLM_OWNER_PASSWORD=zainkhokhar@1
SOLOLLM_SESSION_SECRET=4dc2e871-ec0d-4fd6-a7a0-496aa9c40511

# Optional feature switches for server deployments.
SOLOLLM_AGENT_ENABLED=true
SOLOLLM_ACADEMIC_ENABLED=true
SOLOLLM_EXPORT_IMPORT_ENABLED=true
SOLOLLM_TRAINING_ENABLED=true
SOLOLLM_QUANTIZE_ENABLED=true
SOLOLLM_RUNTIME_MANAGEMENT_ENABLED=true

# Optional admin token for direct API/OpenAI-compatible clients.
SOLOLLM_ADMIN_API_TOKEN=